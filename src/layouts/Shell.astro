---
import '../styles/shell.css';
import Base from './Base.astro';
import Footer from '../components/Footer.astro';
import { getNotes, SITE_TITLE } from '../lib/db.js';

interface Props {
  title: string;
  activeSlug?: string;
}

const { title, activeSlug } = Astro.props;
const { notes: rawNotes } = await getNotes();

const notebookMap = rawNotes.reduce((acc, note) => {
  if (!acc[note.folderTitle]) acc[note.folderTitle] = [];
  acc[note.folderTitle].push(note);
  return acc;
}, {} as Record<string, typeof rawNotes>);

const sortedNotebooks = Object.entries(notebookMap)
  .sort(([a], [b]) => a.localeCompare(b));

for (const [, notes] of sortedNotebooks) {
  notes.sort((a, b) => a.title.localeCompare(b.title));
}
---

<Base title={title}>
  <div class="shell">
    <nav class="sidebar">
      <a href="/" class="site-title">
        <span class="site-icon">&#9672;</span>
        <span>{SITE_TITLE}</span>
      </a>
      <div class="notebooks">
        {sortedNotebooks.map(([notebook, notes]) => (
          <div class="notebook">
            <details open={notes.some(n => n.slug === activeSlug)}>
              <summary class="notebook-label">{notebook}</summary>
              <ul>
                {notes.map(note => (
                  <li>
                    <a
                      href={`/${note.slug}`}
                      class:list={['note-link', { active: note.slug === activeSlug }]}
                    >
                      {note.title}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          </div>
        ))}
      </div>
    </nav>
    <main class="content">
      <slot />
      <Footer />
    </main>
  </div>
</Base>
