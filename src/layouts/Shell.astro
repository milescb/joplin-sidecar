---
import '../styles/shell.css';
import Base from './Base.astro';
import Footer from '../components/Footer.astro';
import { getNotes, SITE_TITLE } from '../lib/db.js';

interface Props {
  title: string;
  activeSlug?: string;
}

const { title, activeSlug } = Astro.props;
const { notes: rawNotes } = await getNotes();
const notes = [...rawNotes].sort((a, b) => a.title.localeCompare(b.title));
---

<Base title={title}>
  <div class="shell">
    <nav class="sidebar">
      <a href="/" class="site-title">
        <span class="site-icon">&#9672;</span>
        <span>{SITE_TITLE}</span>
      </a>
      <div class="notebooks">
        <div class="notebook">
          <span class="notebook-label">Published Notes</span>
          <ul>
            {notes.map(note => (
              <li>
                <a
                  href={`/${note.slug}`}
                  class:list={['note-link', { active: note.slug === activeSlug }]}
                >
                  {note.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </nav>
    <main class="content">
      <slot />
      <Footer />
    </main>
  </div>
</Base>
